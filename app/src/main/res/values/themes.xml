<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.IdleTerminal" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">#FBFBFF</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FBFBFF</item>

        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>

        <item name="postSplashScreenTheme">@style/Theme.IdleTerminal</item>
    </style>
</resources>